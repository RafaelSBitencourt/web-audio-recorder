# Supabase configuration
# Copy this file to .env or .env.local and fill in your Supabase credentials.
# If these credentials are missing, the application will fallback to Mock Mode (using IndexedDB and localStorage).

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key
